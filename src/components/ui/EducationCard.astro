---
interface Props {
    eduTitle:string;
    degree:string;
    startDate:string;
    endDate:string;
    items:string[];
}

const {eduTitle, degree, startDate, endDate,items} = Astro.props
---

<div class="group flex flex-col border-4 border-black bg-white hover:-translate-y-2 hover:shadow-[12px_12px_0_0_#000] transition-all duration-300">
    <div class="bg-black text-white p-4 md:p-6 border-b-4 border-black group-hover:bg-[var(--accent)] transition-colors duration-300">
        <h1 class="text-2xl md:text-3xl lg:text-4xl uppercase leading-none">{eduTitle}</h1>
    </div>
    
    <div class="relative px-4 md:px-6 pt-6 pb-6">
        <div class="absolute -top-5 left-4 md:left-6 bg-white border-2 border-black font-mono text-xs md:text-sm uppercase font-bold px-3 py-1 shadow-[4px_4px_0_0_#000] group-hover:bg-black group-hover:text-white transition-colors duration-300">
            {degree} <span class="mx-1 font-normal opacity-50">||</span> {startDate} - {endDate}
        </div>

        <ul class="flex flex-col gap-4 mt-2 text-sm md:text-base lg:text-lg">
            {items.map((item) => (
                <li class="flex items-start gap-3">
                    <span class="text-[var(--accent)] font-bold font-mono mt-0.5 group-hover:text-black transition-colors duration-300 text-xl leading-none">>&nbsp;</span>
                    <span class="leading-relaxed font-mono">{item}</span>
                </li>
            ))}
        </ul>
    </div>
</div>