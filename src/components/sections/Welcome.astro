---
import Button from '../ui/Button.astro';
import Icon from '../ui/Icon.astro';
import { Image } from 'astro:assets';
import MePhoto from "../../assets/images/me.jpeg";
import X from "../../assets/xSVG.svg";

interface Props {
    i18n: {
        badgeInfo: string;
        contact: string;
        currentlyIn: string;
        doodles: {
            hero: string;
            role: string;
            thatsMe: string;
            sayHi: string;
            todoShipV2: string;
        };
    };
    personalGags?: { [key: string]: string };
}

const { i18n, personalGags } = Astro.props;
const {badgeInfo, contact, currentlyIn, doodles} = i18n;

const logoStyles ="w-[32px] h-[32px] md:hover:w-[48px] md:hover:h-[48px] transition-all duration-300 ease-in-out";

const logoList = [
    { name: "apple", pos: "md:absolute md:top-[-12%] md:left-[80%]", anim: "md:animate-float-fast" },
    { name: "arch", pos: "md:absolute md:top-[0%] md:right-[-10%]", anim: "md:animate-float-slow" },
    { name: "spotify", pos: "md:absolute md:top-[-10%] md:left-[95%]", anim: "md:animate-float-fast" },

    /* 
    Left top Corner Logo Positions
    Top Cálculus: (8 * n) starting from 50%
    Left Side First Column: Left -15%
    Left Side Second Column: Left-30%
    */
    { name: "figma", pos: "md:absolute md:top-[50%] md:left-[-15%]" , anim: "md:animate-float-slow"},
    { name: "node", pos: "md:absolute md:top-[58%] md:left-[-30%]", anim: "md:animate-float-fast" },
    { name: "obsidian", pos: "md:absolute md:top-[66%] md:left-[-15%]", anim: "md:animate-float-fast" },
    { name: "markdown", pos: "md:absolute md:top-[74%] md:left-[-30%]", anim: "md:animate-float-slow" },
    { name: "react", pos: "md:absolute md:top-[82%] md:left-[-15%]", anim: "md:animate-float-slow" },
    { name: "typescript", pos: "md:absolute md:top-[90%] md:left-[-30%]" , anim: "md:animate-float-fast"},
    { name: "latex", pos: "md:absolute md:top-[98%] md:left-[-15%]", anim: "md:animate-float-slow" },

    /* Bottom Left Logo Positions */
    { name: "python", pos: "md:absolute md:top-[105%] md:left-[0%]", anim: "md:animate-float-fast" },
    { name: "tailwind", pos: "md:absolute md:top-[110%] md:left-[15%]", anim: "md:animate-float-slow" },
    { name: "javascript", pos: "md:absolute md:top-[105%] md:left-[30%]", anim: "md:animate-float-fast" }
];
---

<section id="about" class="welcomeContainer max-w-screen-xl mx-auto flex flex-col pt-8 md:pt-16 px-6 md:px-16 md:mb-12 relative">
    <span class="hidden xl:block absolute left-2 lg:-left-6 top-32 font-handwriting text-3xl text-gray-800 -rotate-12">{doodles.hero}</span>
    {personalGags && (
        <a href="https://music.apple.com/co/playlist/tatos-liked-songs/pl.u-76oNNrNFvPBYPEM?l=en" target="_blank" class="hidden xl:flex absolute top-[90%] right-[5%] items-center gap-3 font-handwriting text-3xl text-[var(--accent)] rotate-12 hover:scale-110 transition-transform z-30">
            <span>{personalGags.appleMusic}</span>
            <img src="/images/Icons/dddoodle-pack/arrows/arrow-8.svg" class="w-12 h-auto rotate-90" alt=""/>
        </a>
    )}
    <div class="flex flex-col lg:flex-row items-center lg:items-start justify-between gap-8 w-full relative lg:pt-10">
        <div class="infoContainer flex flex-col gap-6 py-4 w-full lg:w-3/5 z-10 items-center lg:items-start text-center lg:text-left" transition:animate="slide">
            <div class="badgeContainer flex border-4 border-black bg-[var(--accent)] text-white uppercase w-fit py-2 px-6 shadow-[4px_4px_0_0_#000] relative">
                {badgeInfo}
                <span class="hidden xl:block absolute -right-28 top-0 font-handwriting text-2xl text-gray-800 -rotate-3 whitespace-nowrap">{doodles.role}</span>
            </div>
            <h1 class="nameContainer flex flex-col uppercase text-6xl sm:text-7xl md:text-[6.5rem] lg:text-[6rem] xl:text-[9rem] leading-[0.85] m-0">
                <span id="firstName">Santiago</span>
                <span>Naranjo</span>
                <span>Herrera</span>
            </h1>

            <a href="https://otrofy.com" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 border-4 border-black bg-white px-4 py-2.5 shadow-[4px_4px_0_0_#000] w-fit hover:-translate-y-1 hover:shadow-[6px_6px_0_0_#000] rotate-2 transition-all duration-300">
                <span class="font-mono text-sm uppercase font-bold text-gray-700">{currentlyIn}</span>
                <div class="h-6 flex items-center">
                    <Icon name="otrofy" className="h-6 w-auto" />
                </div>
            </a>

            <div class="contactContainer flex flex-wrap gap-4 justify-center lg:justify-start mt-4 relative">
                <Button text={contact} href="mailto:naranjosa2004@gmail.com"/>
                <Button text='Github' href='https://github.com/TatoNaranjo' variant='white'/>
                <Button text='+57 3143109118' href='https://wa.me/3143109118' variant='white'/>
                
                <span class="hidden lg:block absolute -bottom-16 left-24 font-handwriting text-2xl text-gray-800 rotate-6 whitespace-nowrap">{doodles.sayHi}</span>
                <img src="/images/Icons/dddoodle-pack/lines/line-5.svg" class="hidden lg:block absolute -bottom-14 left-4 w-24 h-auto -rotate-6 opacity-80" alt="" />
            </div>
        </div>

        <div class="photoFrame flex flex-col items-center lg:items-end justify-center w-full lg:w-2/5 z-0 mt-8 lg:mt-0">
            <div class="relative inline-block w-[280px] h-[380px] md:w-[360px] md:h-[480px]">
                <X class="absolute -top-10 -left-10 w-[89px] h-[89px] max-sm:hidden z-20"/>
                
                <span class="hidden lg:block absolute -top-12 md:-top-14 left-[40%] -translate-x-1/2 font-handwriting text-2xl text-gray-800 -rotate-3 whitespace-nowrap z-30">{doodles.thatsMe}</span>
                <img src="/images/Icons/dddoodle-pack/arrows/arrow-14.svg" class="hidden lg:block absolute -top-16 left-[60%] w-16 h-auto opacity-80 z-30" alt="" />
                <span class="hidden lg:block absolute -bottom-6 -right-6 font-handwriting text-xl text-[var(--accent)] bg-white border-2 border-[var(--accent)] px-3 py-1 rotate-3 shadow-[4px_4px_0_0_var(--accent)] z-30">{doodles.todoShipV2}</span>

                <Image src={MePhoto} alt="Santiago Naranjo Herrera" width={595} height={954} class="w-full h-full object-cover border-4 border-black shadow-[8px_8px_0_0_#000]" priority/>
                
                <div class="logoContainers hidden md:block absolute inset-0 pointer-events-none z-10">
                    {logoList.map(logo =>(
                       <Icon 
                            name={logo.name} 
                            className={`${logoStyles} ${logo.pos} ${logo.anim} pointer-events-auto`}
                        />
                    ))}
                </div>
            </div>

            <div class="logoContainers flex md:hidden flex-wrap gap-4 justify-center mt-8 w-full max-w-[280px]">
                {logoList.map(logo =>(
                   <Icon 
                        name={logo.name} 
                        className={`${logoStyles} pointer-events-auto`}
                    />
                ))}
            </div>
        </div>
    </div>
</section>

<!-- Infinite Marquee -->
<div class="w-full border-y-4 border-black bg-[var(--accent)] overflow-hidden py-3 mt-24 mb-8 flex relative">
    <div class="flex whitespace-nowrap animate-[marquee_20s_linear_infinite] font-mono text-xl md:text-2xl font-bold uppercase tracking-wider text-white">
        {Array(10).fill("REACT • TYPESCRIPT • VITE • FLUTTER • NODE.JS • PYTHON • MACHINE LEARNING • SQL • ").map((text) => <span>{text}&nbsp;</span>)}
    </div>
</div>