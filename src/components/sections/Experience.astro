---
import SectionTitle from '../ui/SectionTitle.astro';
import { Image } from 'astro:assets';
interface ExperienceItem{
        role:string;
        company:string;
        duration:string;
        imgName:string;
        items:string[];
}

interface Props {
    
    sectionTitle: string;
    expStrings: {
    item: ExperienceItem[];  
} 
    gag?: string;
    personalGags?: { [key: string]: string };
}
const {expStrings, sectionTitle, gag, personalGags} = Astro.props;
const allImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/*.*', { eager: true });

const groupedExperiences = expStrings.item.reduce((acc, curr) => {
    const existingGroup = acc.find(group => group.company === curr.company);
    if (existingGroup) {
        existingGroup.roles.push({
            role: curr.role,
            duration: curr.duration,
            items: curr.items
        });
    } else {
        acc.push({
            company: curr.company,
            imgName: curr.imgName,
            roles: [{
                role: curr.role,
                duration: curr.duration,
                items: curr.items
            }]
        });
    }
    return acc;
}, [] as { company: string, imgName: string, roles: { role: string, duration: string, items: string[] }[] }[]);
---
<section class="border-b-8 border-black relative">
<div class="max-w-screen-xl mx-auto flex flex-col items-center justify-center md:items-start md:justify-between gap-8 px-6 py-16 md:py-24 relative">
{personalGags && <span class="hidden xl:block absolute top-[60%] -left-60 font-handwriting text-2xl text-gray-800 rotate-12 whitespace-nowrap">{personalGags.guitar}</span>}
<img src="/images/Icons/dddoodle-pack/misc/misc-24.svg" class="hidden xl:block absolute top-[10%] -right-40 w-32 h-auto opacity-50 rotate-[-15deg] -z-10" alt="" loading="lazy" />
<img src="/images/Icons/dddoodle-pack/misc/misc-25.svg" class="hidden xl:block absolute top-[50%] -left-48 w-40 h-auto opacity-50 rotate-12 -z-10" alt="" loading="lazy" />
<img src="/images/Icons/dddoodle-pack/misc/misc-26.svg" class="hidden xl:block absolute bottom-[10%] -right-32 w-24 h-auto opacity-50 rotate-45 -z-10" alt="" />
<img src="/images/Icons/dddoodle-pack/misc/misc-11.svg" class="hidden md:block absolute top-12 left-[350px] w-12 h-auto opacity-70 -rotate-12" alt="" />
{gag && <span class="hidden xl:block absolute top-[15%] -left-60 font-handwriting text-2xl text-gray-800 rotate-[15deg] whitespace-nowrap">{gag}</span>}
<SectionTitle text={sectionTitle} rotation="-rotate-3" />

<div class="w-full">
    <div class="w-full">
        
       {groupedExperiences.map((group) => {
           if (group.roles.length === 1) {
               const role = group.roles[0];
               return (
                    <div class="mb-8 flex flex-col md:flex-row border-4 items-stretch bg-white">
                        <div class="w-full h-48 md:w-64 md:h-auto shrink-0 border-b-4 md:border-b-0 md:border-r-4 border-black">
                            <Image 
                                src={allImages[`/src/assets/images/${group.imgName}`].default} 
                                alt={group.company} 
                                class="w-full h-full object-cover"
                            />
                        </div>

                        <div class="flex flex-col grow">
                            <div class="text-white text-sm bg-black flex flex-col md:items-start items-center text-center md:text-start justify-center p-6 gap-2">
                                <h3 class="text-2xl md:text-3xl lg:text-4xl">{role.role}</h3>
                                <h4 class="text-lg md:text-xl font-mono uppercase">{group.company}</h4>
                                <span class="font-mono text-xs md:text-sm border border-white px-2 py-1">{role.duration}</span>
                            </div>
                            <ul class="list-disc list-inside p-6 flex flex-col grow justify-center text-sm md:text-base lg:text-lg">
                                {role.items.map((item) => (
                                    <li>{item}</li>
                                ))}
                            </ul>
                        </div>
                    </div>
               );
           }

           return (
                <div class="mb-8 flex flex-col md:flex-row border-4 items-stretch bg-white">
                    <div class="w-full h-48 md:w-64 md:h-auto shrink-0 border-b-4 md:border-b-0 md:border-r-4 border-black">
                        <Image 
                            src={allImages[`/src/assets/images/${group.imgName}`].default} 
                            alt={group.company} 
                            class="w-full h-full object-cover"
                        />
                    </div>

                    <div class="flex flex-col grow">
                        <div class="text-white text-sm bg-black flex flex-col md:items-start items-center text-center md:text-start justify-center p-6 gap-2">
                            <h3 class="text-2xl md:text-3xl lg:text-4xl uppercase">{group.company}</h3>
                        </div>
                        
                        <div class="p-6 flex flex-col grow justify-center text-sm md:text-base lg:text-lg">
                            {group.roles.map((role, index) => (
                                <div class="flex relative">
                                    <div class="flex flex-col items-center mr-6 mt-2 shrink-0">
                                        <div class="w-3 h-3 bg-black rounded-full"></div>
                                        {index !== group.roles.length - 1 && (
                                            <div class="w-0.5 h-full bg-black my-1"></div>
                                        )}
                                    </div>
                                    
                                    <div class="pb-6 w-full">
                                        <h4 class="text-xl md:text-2xl font-bold">{role.role}</h4>
                                        <span class="font-mono text-xs md:text-sm border border-black px-2 py-1 inline-block my-2">{role.duration}</span>
                                        <ul class="list-disc list-inside mt-2">
                                            {role.items.map((item) => (
                                                <li class="mb-1">{item}</li>
                                            ))}
                                        </ul>
                                    </div>
                                </div>
                            ))}
                        </div>
                    </div>
                </div>
           );
       })}
    </div>
</div>
</div>
</section>