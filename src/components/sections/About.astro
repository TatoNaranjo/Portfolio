---
import SectionTitle from '../ui/SectionTitle.astro';
interface Props{
    title:string;
    content:string[];
    gag?:string;
    personalGags?: { [key: string]: string };
}
const {title, content, gag, personalGags} = Astro.props;
---
<section class="border-t-8 border-b-8 border-black relative">
<div class="max-w-screen-xl mx-auto flex flex-col md:flex-row items-center justify-center md:justify-between gap-8 px-6 py-16 md:py-24 relative">
{personalGags && <span class="hidden xl:block absolute top-[65%] left-32 font-handwriting text-2xl text-gray-800 rotate-[-5deg] whitespace-nowrap">{personalGags.bookstore}</span>}
<img src="/images/Icons/dddoodle-pack/misc/misc-15.svg" class="hidden xl:block absolute top-[20%] -left-32 w-24 h-auto opacity-50 rotate-12 -z-10" alt="" loading="lazy" />
<img src="/images/Icons/dddoodle-pack/misc/misc-16.svg" class="hidden xl:block absolute bottom-[20%] -right-32 w-32 h-auto opacity-50 -rotate-12 -z-10" alt="" loading="lazy" />
<img src="/images/Icons/dddoodle-pack/lines/line-3.svg" class="hidden md:block absolute top-16 left-[28%] w-24 h-auto opacity-70 rotate-12" alt="" loading="lazy" />
{gag && <span class="hidden xl:block absolute top-[25%] -right-24 font-handwriting text-2xl text-gray-800 -rotate-12 whitespace-nowrap">{gag}</span>}
<SectionTitle text={title} rotation="rotate-2" />

<div class="bg-[#f2f2f2] border-4 p-8 text-sm md:text-base lg:text-lg md:max-w-[50%] relative">
    <img src="/images/Icons/dddoodle-pack/arrows/arrow-4.svg" class="hidden md:block absolute -top-12 -right-12 w-20 h-auto opacity-70 rotate-[20deg]" alt="" />
    {content.map(paragraph => (
        <p class="mb-4 last:mb-0">{paragraph}</p>
    ))}
</div>
</div>
</section>