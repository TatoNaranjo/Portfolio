---
interface Props {
  subtitle: string;
  personalGags?: { [key: string]: string };
}
const { subtitle, personalGags } = Astro.props;
---

<div class="bg-black text-white p-[18px] relative">
  {personalGags && <span class="hidden xl:block absolute top-[10%] right-[10%] font-handwriting text-2xl text-white opacity-80 -rotate-12 z-20 whitespace-nowrap">{personalGags.tatoWasHere}</span>}
  <img src="/images/Icons/scribbles-free-svg/Scribble-7.svg" class="hidden md:block absolute top-[20%] left-12 w-24 h-auto opacity-50 invert rotate-12" alt="" loading="lazy" />
  <img src="/images/Icons/scribbles-free-svg/Scribble-8.svg" class="hidden md:block absolute bottom-[20%] right-12 w-32 h-auto opacity-50 invert -rotate-6" alt="" />
  <div class="max-w-screen-xl mx-auto flex flex-col md:justify-between text-center md:text-start relative z-10">
    <div class="flex flex-col md:flex-row md:justify-between gap-10">
      <div class="flex flex-col">
        <span class="uppercase text-lg md:text-3xl lg:text-4xl font-mono font-bold"><span class="text-[var(--accent)]">&gt;_</span> Santiago Naranjo Herrera</span>
        <span class="text-xs md:text-base lg:text-lg mt-2 font-mono">{subtitle}</span>
      </div>

      <div class="flex flex-col text-center md:text-start gap-4 font-mono font-bold">
        <a href="mailto:naranjosa2004@gmail.com" class="text-4xl md:text-5xl lg:text-7xl uppercase hover:text-[var(--accent)] transition-colors w-fit">[LETS_TALK]</a>
        <a href="https://github.com/TatoNaranjo" target="_blank" class="text-4xl md:text-5xl lg:text-7xl uppercase hover:text-[var(--accent)] transition-colors w-fit">[GITHUB]</a>
        <span class="text-xl md:text-2xl mt-4 font-mono">+57 3143109118</span>
      </div>
    </div>
    
    <span class="text-center my-5 text-xs md:text-sm">© 2026 - BUILT BY TATONARANJO</span>
  </div>
</div>
