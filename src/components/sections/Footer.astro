---
interface Props {
  subtitle: string;
}
const { subtitle } = Astro.props;
---

<div class="bg-black text-white p-[18px]">
  <div class="max-w-screen-xl mx-auto flex flex-col md:justify-between text-center md:text-start">
    <div class="flex flex-col md:flex-row md:justify-between gap-10">
      <div class="flex flex-col">
        <span class="uppercase text-lg md:text-3xl lg:text-4xl">Santiago Naranjo Herrera</span>
        <span class="text-xs md:text-base lg:text-lg">{subtitle}</span>
      </div>

      <div class="flex flex-col text-center md:text-start gap-4">
        <a href="mailto:naranjosa2004@gmail.com" class="text-4xl md:text-5xl lg:text-7xl font-bold uppercase hover:text-[var(--accent)] hover:underline decoration-4 underline-offset-8 transition-colors">Let's Talk &rarr;</a>
        <a href="https://github.com/TatoNaranjo" target="_blank" class="text-4xl md:text-5xl lg:text-7xl font-bold uppercase hover:text-[var(--accent)] hover:underline decoration-4 underline-offset-8 transition-colors">GitHub &rarr;</a>
        <span class="text-xl md:text-2xl mt-4 font-mono">+57 3143109118</span>
      </div>
    </div>
    
    <span class="text-center my-5 text-xs md:text-sm">© 2026 - BUILT BY TATONARANJO</span>
  </div>
</div>
