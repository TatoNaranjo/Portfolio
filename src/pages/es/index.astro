---
import "../../styles/global.css";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/sections/Header.astro";
import Welcome from "../../components/sections/Welcome.astro";
import About from "../../components/sections/About.astro";
import text_es from "../../i18n/es.json"
import Experience from "../../components/sections/Experience.astro";
import Projects from "../../components/sections/Projects.astro";
import LatestPosts from "../../components/sections/LatestPosts.astro";
import Skills from "../../components/sections/Skills.astro";
import Education from "../../components/sections/Education.astro";
import Footer from "../../components/sections/Footer.astro";

let {altLang} = text_es;
---

<Layout 
  lang="es" 
  title="Santiago Naranjo Herrera | Full-Stack Software Engineer" 
  description="Portafolio de Santiago Naranjo Herrera, Full-Stack Software Engineer. Descubre mis proyectos, experiencia y habilidades."
>
  <Header altLang=`${altLang}`/>
  <Welcome i18n={text_es.welcome} personalGags={text_es.personalGags} />
  <About title={text_es.about.sectionTitle} content={text_es.about.content} gag={text_es.gags.about} personalGags={text_es.personalGags} />
  <LatestPosts sectionTitle={text_es.latestPosts.sectionTitle} gag={text_es.gags.blog} personalGags={text_es.personalGags} />
  <Experience sectionTitle={text_es.experience.sectionTitle} expStrings={text_es.experience} gag={text_es.gags.experience} personalGags={text_es.personalGags} />
  <Skills sectionTitleLeft={text_es.skills.sectionTitle[0]} sectionTitleRight={text_es.skills.sectionTitle[1]} languages={text_es.languages} gag={text_es.gags.skills}/>
  <Projects sectionTitle={text_es.projects.sectionTitle} projectStrings={text_es.projects} gag={text_es.gags.projects} personalGags={text_es.personalGags} />
  <Education sectionTitle={text_es.education.sectionTitle} eduStrings={text_es.education} gag={text_es.gags.education}/>
  <Footer subtitle={text_es.footer.subtitle} personalGags={text_es.personalGags} />
</Layout>
